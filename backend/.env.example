# Server Configuration
# PORT: Railway sets this automatically in production — no need to configure manually
PORT=3001
NODE_ENV=development

# Railway Production
# Required on Railway: set NODE_ENV=production in your Railway environment variables
# NODE_ENV=production

# Security
# SESSION_SECRET: use a cryptographically random string of at least 32 characters in production
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
APP_PASSWORD=qwiso123

# Data directories (relative to backend root or absolute)
# WARNING (Railway): Railway's filesystem is ephemeral — data is wiped on every deploy.
# To persist the SQLite database and WhatsApp sessions across deploys, attach a Railway
# Volume and set these paths to point inside it, e.g.:
#   DB_PATH=/data/db/qwiso.db
#   WA_AUTH_PATH=/data/sessions
DB_PATH=../data/db/qwiso.db
WA_AUTH_PATH=../data/sessions

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WhatsApp / Baileys settings
# No Chrome/Puppeteer required - Baileys uses native WebSocket connection

# CORS — comma-separated list of allowed origins
# Only needed when the frontend is on a DIFFERENT origin than the backend.
# NOT required for standard Railway deployments where Express serves the
# Vite-built frontend from the same origin (same domain, no CORS needed).
# Development: localhost frontend talking to a separate backend process
# Cross-origin production: e.g. Cloudflare Workers frontend → Railway backend
CORS_ORIGIN=https://qwiso.silaskodes.workers.dev,http://localhost:5173
