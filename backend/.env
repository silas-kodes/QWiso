# Server Configuration
PORT=3001
NODE_ENV=development

# Security
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
APP_PASSWORD=qwiso123

# Data directories (relative to backend root or absolute)
DB_PATH=../data/db/qwiso.db
WA_AUTH_PATH=../data/sessions

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WhatsApp settings
WA_HEADLESS=true
WA_DEVTOOLS=false
WA_AUTO_START=true

# CORS (for development)
CORS_ORIGIN=http://localhost:5173

# TextBee SMS Gateway (https://textbee.dev)
# 1. Register at textbee.dev (free)
# 2. Install the TextBee app on your Android phone
# 3. Register your device at textbee.dev/dashboard to get these values
TEXTBEE_API_KEY=your-textbee-api-key-here
TEXTBEE_DEVICE_ID=your-textbee-device-id-here
