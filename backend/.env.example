# Server Configuration
PORT=3001
NODE_ENV=development

# Security
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
APP_PASSWORD=qwiso123

# Data directories (relative to backend root or absolute)
DB_PATH=../data/db/qwiso.db
WA_AUTH_PATH=../data/sessions

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WhatsApp settings
WA_HEADLESS=true
WA_DEVTOOLS=false

# CORS — comma-separated list of allowed origins
# Development: just localhost
# Production: add your Cloudflare Workers frontend domain
CORS_ORIGIN=https://qwiso.silaskodes.workers.dev,http://localhost:5173
